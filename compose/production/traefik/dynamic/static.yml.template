http:
  routers:
    web-secure-router:
      rule: '(Host(`${DJANGO_DOMAIN}`) || Host(`www.${DJANGO_DOMAIN}`)) && (PathPrefix(`/api/`) || PathPrefix(`/_allauth/`) || PathPrefix(`/admin/`))'
      entryPoints:
        - web-secure
      middlewares:
        - csrf
      service: django
      tls:
        certResolver: letsencrypt

    frontend-secure-router:
      rule: 'Host(`${DJANGO_DOMAIN}`) || Host(`www.${DJANGO_DOMAIN}`)'
      entryPoints:
        - web-secure
      service: frontend
      tls:
        certResolver: letsencrypt
      priority: 1

    flower-secure-router:
      rule: 'Host(`${DJANGO_DOMAIN}`)'
      entryPoints:
        - flower
      service: flower
      tls:
        certResolver: letsencrypt

    web-media-router:
      rule: '(Host(`${DJANGO_DOMAIN}`) || Host(`www.${DJANGO_DOMAIN}`)) && PathPrefix(`/media/`)'
      entryPoints:
        - web-secure
      middlewares:
        - csrf
      service: django-media
      tls:
        certResolver: letsencrypt

  middlewares:
    csrf:
      headers:
        hostsProxyHeaders: ['X-CSRFToken']

  services:
    django:
      loadBalancer:
        servers:
          - url: http://django:5000

    flower:
      loadBalancer:
        servers:
          - url: http://flower:5555

    django-media:
      loadBalancer:
        servers:
          - url: http://nginx:80

    frontend:
      loadBalancer:
        servers:
          - url: http://frontend:3000

# Pre-issue the wildcard *.${APPS_DOMAIN} certificate once at startup via the
# DNS-01 resolver and serve it from the default store.  Per-app routers use
# ``tls: {}`` and so pick this wildcard up automatically by SNI — no per-app
# certificate is requested.
tls:
  stores:
    default:
      defaultGeneratedCert:
        resolver: letsencrypt-dns
        domain:
          main: '${APPS_DOMAIN}'
          sans:
            - '*.${APPS_DOMAIN}'
