http:
  routers:
    web-secure-router:
      rule: '(Host(`${DJANGO_DOMAIN}`) || Host(`www.${DJANGO_DOMAIN}`)) && (PathPrefix(`/api/`) || PathPrefix(`/_allauth/`) || PathPrefix(`/admin/`))'
      entryPoints:
        - web-secure
      middlewares:
        - csrf
      service: django
      tls:
        certResolver: letsencrypt

    frontend-secure-router:
      rule: 'Host(`${DJANGO_DOMAIN}`) || Host(`www.${DJANGO_DOMAIN}`)'
      entryPoints:
        - web-secure
      service: frontend
      tls:
        certResolver: letsencrypt
      priority: 1

    flower-secure-router:
      rule: 'Host(`${DJANGO_DOMAIN}`)'
      entryPoints:
        - flower
      service: flower
      tls:
        certResolver: letsencrypt

    web-media-router:
      rule: '(Host(`${DJANGO_DOMAIN}`) || Host(`www.${DJANGO_DOMAIN}`)) && PathPrefix(`/media/`)'
      entryPoints:
        - web-secure
      middlewares:
        - csrf
      service: django-media
      tls:
        certResolver: letsencrypt

  middlewares:
    csrf:
      headers:
        hostsProxyHeaders: ['X-CSRFToken']

  services:
    django:
      loadBalancer:
        servers:
          - url: http://django:5000

    flower:
      loadBalancer:
        servers:
          - url: http://flower:5555

    django-media:
      loadBalancer:
        servers:
          - url: http://nginx:80

    frontend:
      loadBalancer:
        servers:
          - url: http://frontend:3000
