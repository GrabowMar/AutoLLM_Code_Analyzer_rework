log:
  level: INFO

entryPoints:
  web:
    address: ':80'
    http:
      redirections:
        entryPoint:
          to: web-secure

  web-secure:
    address: ':443'

  flower:
    address: ':5555'

# Sample apps are NOT given dedicated entry points/ports anymore.  Each app is
# reached on the shared web-secure (:443) entry point via a unique subdomain
# (<container_name>.<APPS_DOMAIN>) and routed to the container on the llm_apps
# Docker network.  See dynamic/app-<name>.yml (written by Django at runtime).

certificatesResolvers:
  # HTTP-01 — used for the apex/www domain (single-host certs).
  letsencrypt:
    acme:
      email: '${LETSENCRYPT_EMAIL}'
      storage: /etc/traefik/acme/acme.json
      httpChallenge:
        entryPoint: web

  # DNS-01 — required to issue the wildcard *.${APPS_DOMAIN} cert that fronts
  # every sample-app subdomain.  Provider + credentials come from env
  # (TRAEFIK_DNS_PROVIDER plus the provider's own vars, e.g. CF_DNS_API_TOKEN).
  letsencrypt-dns:
    acme:
      email: '${LETSENCRYPT_EMAIL}'
      storage: /etc/traefik/acme/acme-dns.json
      dnsChallenge:
        provider: '${TRAEFIK_DNS_PROVIDER}'

providers:
  # Static routes (django, frontend, flower) + the wildcard TLS store live in
  # dynamic/static.yml.  Per-container routes are written to
  # dynamic/app-<name>.yml at runtime.
  file:
    directory: /etc/traefik/dynamic/
    watch: true
