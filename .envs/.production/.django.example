# Production Django environment.
# Copy to `.envs/.production/.django` and fill in real values.
# Do NOT commit the real file — it's gitignored.
# ------------------------------------------------------------------------------

# Domain — used throughout: traefik routing, ALLOWED_HOSTS default,
# DEFAULT_FROM_EMAIL default, vite allowedHosts, OpenRouter HTTP-Referer.
DJANGO_DOMAIN=example.com

# Secrets
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=
DJANGO_ADMIN_URL=
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Security
# ------------------------------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False

# Email
# ------------------------------------------------------------------------------
MAILGUN_API_KEY=
DJANGO_SERVER_EMAIL=
MAILGUN_DOMAIN=

# AWS
# ------------------------------------------------------------------------------
DJANGO_AWS_ACCESS_KEY_ID=
DJANGO_AWS_SECRET_ACCESS_KEY=
DJANGO_AWS_STORAGE_BUCKET_NAME=

# django-allauth
# ------------------------------------------------------------------------------
DJANGO_ACCOUNT_ALLOW_REGISTRATION=True
# Browser-facing app URL (https) — used in verification and password-reset emails.
FRONTEND_PUBLIC_ORIGIN=https://example.com

# Sample-app container access (Traefik bridge — subdomain routing)
# ------------------------------------------------------------------------------
# TRAEFIK_DYNAMIC_DIR and DOCKER_APPS_NETWORK are set automatically by
# docker-compose.production.yml — do not override here unless you know what
# you're doing.
#
# Each generated sample app is reached on a UNIQUE SUBDOMAIN through Traefik:
#   https://<container_name>.<APPS_DOMAIN>/
# Django writes a per-container route file; Traefik routes the subdomain to the
# container over the llm_apps network (no host ports, no per-app port limit).
# TLS is served from a single wildcard *.<APPS_DOMAIN> certificate.
#
# APPS_DOMAIN — base domain for app subdomains. Defaults to DJANGO_DOMAIN.
# A DEDICATED subdomain (e.g. apps.example.com) is recommended so the wildcard
# stays scoped; you then need DNS: *.apps.example.com -> this host.
# (Traefik also reads this — it loads .django — to request the wildcard cert.)
APPS_DOMAIN=apps.example.com

# The wildcard *.APPS_DOMAIN TLS cert needs the Let's Encrypt DNS-01 challenge.
# Its provider + credentials live in .envs/.production/.traefik (loaded only by
# the Traefik container) — see .traefik.example.

# CONTAINER_APP_HOST is only used when TRAEFIK_DYNAMIC_DIR is NOT set (e.g.
# local dev without Traefik), where apps bind a host port instead.  Leave empty
# to fall back to DJANGO_DOMAIN.
CONTAINER_APP_HOST=


# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery Flower
# ------------------------------------------------------------------------------
CELERY_FLOWER_USER=
CELERY_FLOWER_PASSWORD=

# OpenRouter — get a key at https://openrouter.ai/keys
# ------------------------------------------------------------------------------
# Optional global fallback key. In production we recommend leaving this empty
# and requiring every user to add their own key via Settings → API Access
# (stored encrypted in the DB). Set OPENROUTER_ALLOW_GLOBAL_KEY_FALLBACK=False
# to enforce per-user keys.
OPENROUTER_API_KEY=
OPENROUTER_ALLOW_GLOBAL_KEY_FALLBACK=False
